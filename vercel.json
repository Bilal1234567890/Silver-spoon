{
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
      { "src": "/[^/]+\\.[^/]+$", "dest": "/$0" },
      { "src": "/(.*)", "dest": "/index.html" }
  ]
}